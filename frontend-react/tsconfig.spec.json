{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["jest", "jest-environment-jsdom", "node", "@testing-library/jest-dom"],
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.test.tsx", "src/**/*.test.ts", "setupTests.ts", "src/vite-env.d.ts"]
}